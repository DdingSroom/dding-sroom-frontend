{
  "plugins": ["prettier"],
  "env": {
    "es6": true,
    "node": true,
    "browser": true
  },
  "extends": [
    "next/core-web-vitals",
    "eslint:recommended",
    "next/typescript",
    "plugin:import/recommended",
    "prettier"
  ],
  "rules": {
    "import/order": ["warn"],
    "prettier/prettier": "error",
"@next/next/no-img-element": "off"
  },
  "ignorePatterns": ["node_modules/"],
  "settings": {
    "import/resolver": {
      "alias": {
        "map": [
          ["@api", "./src/api/"],
          ["@hooks", "./src/hooks/"],
          ["@utils", "./src/utils/"],
          ["@components", "./src/components/"],
          ["@constants", "./src/constants/"],
          ["@stores", "./src/stores/"]
        ],
        "extensions": [".js", ".jsx", ".ts", ".tsx"]
      }
    }
  }
}
